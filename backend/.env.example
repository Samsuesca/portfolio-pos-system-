# ===========================================
# Uniformes System - Environment Variables
# ===========================================
# Copy this file to .env and update values

# Environment (development | staging | production)
ENV=production
DEBUG=false

# Database (PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://uniformes_user:CHANGE_THIS_PASSWORD@localhost:5432/uniformes_db

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# Security - IMPORTANT: Generate a new secret key for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING

# JWT Token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS Origins (comma-separated)
# Add your frontend domain(s) here
BACKEND_CORS_ORIGINS=["https://uniformes-system.com","https://app.uniformes-system.com","tauri://localhost"]

# Email (Resend) - https://resend.com
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Your Business <noreply@yourdomain.com>

# Frontend URLs (for email links)
FRONTEND_URL=https://yourdomain.com
ADMIN_PORTAL_URL=https://admin.yourdomain.com

# Wompi Payment Gateway - https://comercios.wompi.co
WOMPI_ENABLED=false
WOMPI_ENVIRONMENT=sandbox
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxx
WOMPI_EVENTS_KEY=test_events_xxxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_KEY=test_integrity_xxxxxxxxxxxxxxxxxxxxx
WOMPI_REDIRECT_URL=http://localhost:3000/pago/resultado

# Telegram Monitoring Alerts
# 1. Create bot with @BotFather → get token
# 2. Create group, add bot, send message
# 3. Open https://api.telegram.org/bot<TOKEN>/getUpdates → get chat_id (negative number)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Health Monitoring
# Disk alert threshold (percentage 0-100)
DISK_ALERT_THRESHOLD_PCT=80
# Sample interval for health checks (seconds)
HEALTH_SAMPLE_INTERVAL=300
