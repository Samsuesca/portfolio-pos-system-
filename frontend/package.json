{
  "name": "uniformes-system-frontend",
  "version": "3.2.0",
  "description": "Sistema de Gestión de Uniformes - Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "rm -rf node_modules/.vite && vite",
    "build": "tsc && vite build",
    "build:strict": "tsc && vite build",
    "preview": "vite preview",
    "clean": "rm -rf node_modules/.vite dist",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:clean": "rm -rf node_modules/.vite && tauri dev",
    "tauri:build": "tauri build",
    "tauri:build-windows": "tauri build --target x86_64-pc-windows-msvc",
    "sync-version": "node ../scripts/sync-version.js",
    "sync-version:git": "node ../scripts/sync-version.js --git",
    "release": "pnpm run sync-version && pnpm run tauri:build",
    "release:git": "pnpm run sync-version:git && pnpm run tauri:build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@react-oauth/google": "0.13.5",
    "@tanstack/react-query": "^5.62.0",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-http": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "axios": "^1.6.0",
    "fuse.js": "^7.3.0",
    "jspdf": "4.2.1",
    "lucide-react": "^0.294.0",
    "motion": "12.38.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-hotkeys-hook": "^5.2.4",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.8.0",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "@vitest/coverage-v8": "^1.2.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.9.3",
    "vite": "^4.5.0",
    "vitest": "^1.2.0"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  }
}
