# Supply-chain hardening (mayo 2026)
# Ataques recientes (Shai-Hulud, Mini Shai-Hulud, TanStack) explotaron
# publicaciones nuevas y postinstalls. Estos defaults los mitigan.
# pnpm 11+ ya viene con muchos de estos seguros — los hacemos explicitos
# para que sean visibles, revisables y enforceable a futuro.

minimum-release-age=1440
# Bloquea instalar versiones publicadas hace <1440 min (24h).
# Habria evitado el ataque a TanStack del 11-may-2026 (84 versiones
# maliciosas publicadas en 6 min, retiradas en pocas horas).

block-exotic-subdeps=true
# Bloquea git://, file://, tarball URLs en deps transitivas.

strict-dep-builds=true
# Falla install si una dep necesita correr postinstall y no esta aprobada.
# Aprobaciones se gestionan via pnpm.onlyBuiltDependencies en package.json.

side-effects-cache=false
# Desactiva el cache de side-effects (evita cache poisoning entre runs).

auto-install-peers=true
strict-peer-dependencies=false

# No pedir confirmacion interactiva al purgar node_modules cuando cambia
# la spec de builds aprobados. Necesario para CI y para flujos non-TTY.
confirm-modules-purge=false
